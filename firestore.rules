rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
         request.auth.token.email.endsWith('@topzyfoods.com') ||
         request.auth.token.email == 'admin@topzyfoods.com');
    }

    match /menuItems/{itemId} {
      allow read, write: if true;
    }

    match /specials/{specialId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow create: if true; // guests and authenticated users can place orders
      allow read, update: if true; // users can read their history, admins can manage statuses
      allow delete: if request.auth != null && (
        request.auth.token.email == 'callmimichelle@gmail.com' ||
        request.auth.token.email == 'ransfordnana001@gmail.com' ||
        request.auth.token.email == 'admin@topzyfoods.com'
      );
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
